# ===================== 编译基础配置（效率+适配IPQ60xx） =====================
CONFIG_USE_APK=n
# 关闭开发模式（减少调试冗余）
CONFIG_DEVEL=n
# 强化CCACHE缓存（提升二次编译速度）
CONFIG_CCACHE=y

# ===================== Busybox 精简（仅保留核心） =====================
CONFIG_BUSYBOX_CUSTOM=y
# 仅保留telnet（如需SSH可开启dropbear，telnet非必需可关）
CONFIG_BUSYBOX_CONFIG_TELNET=y
# 禁用Busybox冗余工具
CONFIG_BUSYBOX_CONFIG_FTP=n
CONFIG_BUSYBOX_CONFIG_TELNETD=n
CONFIG_BUSYBOX_CONFIG_WGET=n
CONFIG_BUSYBOX_CONFIG_PING6=n

# ===================== 强制保留NSS（IPQ60xx核心加速，必开） =====================
CONFIG_PACKAGE_nss-utils=y
CONFIG_PACKAGE_kmod-nss=y
CONFIG_PACKAGE_nss-firmware-ipq60xx=y
CONFIG_NSS_CRYPTO=y
CONFIG_NSS_DRIVERS=y
CONFIG_NSS_PROCESSING=y

# ===================== USB 全功能保留（存储/挂载/驱动） =====================
# USB核心驱动
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
# USB存储驱动
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
# USB挂载工具
CONFIG_PACKAGE_usbmount=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_mount-utils=y
# USB网卡（如需USB转网口可保留，否则关）
CONFIG_PACKAGE_kmod-usb-net=n
CONFIG_PACKAGE_kmod-usb-net-asix=n
CONFIG_PACKAGE_kmod-usb-net-rtl8152=n

# ===================== 彻底禁用WiFi（核心需求） =====================
# 禁用无线核心驱动
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6038=n
# 禁用WiFi配置工具
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-mbedtls=n
# 禁用LuCI WiFi相关插件
CONFIG_PACKAGE_luci-app-wifi-config=n
CONFIG_PACKAGE_luci-proto-wifi=n
CONFIG_PACKAGE_luci-mod-network-wifi=n
# 显式关闭无线编译选项
CONFIG_WLAN=n
CONFIG_TARGET_ENABLE_WIFI=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_wireless-tools=n

# ===================== 协议/库（仅保留必需） =====================
# 禁用链路聚合（非必需）
CONFIG_PACKAGE_proto-bonding=n
# WireGuard按需保留（不用可关）
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-proto-relay=n
# 禁用老旧openssl库，启用新版
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_libopenssl-legacy=n
CONFIG_PACKAGE_libopenssl=y

# ===================== 显式禁用冗余包（规避build.sh自动叠加） =====================
# 禁用Docker/代理等冗余组件
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_containerd=n
CONFIG_PACKAGE_runc=n
CONFIG_PACKAGE_xray=n
CONFIG_PACKAGE_v2ray=n
CONFIG_PACKAGE_sing-box=n
# 禁用其他冗余工具
CONFIG_PACKAGE_tcpdump-mini=n
CONFIG_PACKAGE_htop=n
CONFIG_PACKAGE_nano=n

# ===================== 基础设置 =====================
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_PACKAGE_automount=n

# ===================== 性能测试工具（非必需，关闭） =====================
CONFIG_PACKAGE_coremark=n
CONFIG_COREMARK_OPTIMIZE_O3=n
CONFIG_COREMARK_ENABLE_MULTITHREADING=n

# ===================== 防火墙/网络（适配NSS） =====================
# 保留iptables-nft（兼容NSS，不建议替换为纯nftables）
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_nftables=n
# 保留Easytier（如需），禁用其他非必需LuCI插件
CONFIG_PACKAGE_easytier=n
CONFIG_PACKAGE_luci-app-easytier=n
CONFIG_EASYTIER_INCLUDE_WEBCONSOLE=n
CONFIG_PACKAGE_luci-app-istorex=n
CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_luci-app-mosdns=n
CONFIG_PACKAGE_luci-app-oaf=n
CONFIG_PACKAGE_luci-app-pbr=n
CONFIG_PACKAGE_luci-app-smartdns=n
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=n

# ===================== 显式禁用LuCI集合包（避免隐式包含WiFi插件） =====================
CONFIG_PACKAGE_luci-light=n
CONFIG_PACKAGE_luci-full=n
CONFIG_PACKAGE_luci-base=y
